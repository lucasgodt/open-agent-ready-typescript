{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-tests.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-override.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-before-commit.sh"
          }
        ]
      }
    ]
  }
}
{
  "name": "open-agent-ready-typescript",
  "version": "1.0.0",
  "description": "A reference TypeScript codebase engineered so AI agents produce good code in it \u2014 architecture as guardrails, not as documentation.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/main/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "deps": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "verify": "npm run typecheck && npm run lint && npm run deps && npm run specs && npm run test",
    "specs": "node scripts/check-spec-coverage.mjs",
    "new": "node scripts/new-use-case.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
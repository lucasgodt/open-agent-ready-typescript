{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/api/schema/stryker-core.json",
  "testRunner": "vitest",
  "mutate": [
    "src/domain/**/*.ts",
    "src/application/**/*.ts",
    "!src/domain/errors.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 75
  },
  "reporters": [
    "clear-text",
    "progress"
  ]
}